# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://primodata:primodata@localhost:5432/primodata"

# Auth (JWT)
JWT_SECRET="change-this-to-a-random-32-char-string-in-production"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6379

# Storage (DigitalOcean Spaces)
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_BUCKET=primodata-files
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_CDN_URL=https://primodata-files.sgp1.cdn.digitaloceanspaces.com

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI
ANTHROPIC_API_KEY=

# Email
RESEND_API_KEY=
EMAIL_FROM=noreply@primodata.io

# SMS / OTP
MSG91_API_KEY=
MSG91_SENDER_ID=PRIMDT

# Monitoring
SENTRY_DSN=
