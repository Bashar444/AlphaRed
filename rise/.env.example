#--------------------------------------------------------------------
# PrimoData — Environment Template (Hostinger hPanel)
# Copy to .env and fill values
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = YOUR_DB_NAME
database.default.username = YOUR_DB_USER
database.default.password = 'YOUR_DB_PASSWORD'
database.default.DBDriver = MySQLi
database.default.DBPrefix = rise_
database.default.charset  = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci
database.default.port     = 3306

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'https://yourdomain.com/rise/'
app.indexPage = ''

#--------------------------------------------------------------------
# JWT AUTH
#--------------------------------------------------------------------
JWT_SECRET = GENERATE_A_64_CHAR_HEX_SECRET
JWT_TTL    = 86400

#--------------------------------------------------------------------
# CORS
#--------------------------------------------------------------------
CORS_ALLOWED_ORIGIN = https://your-frontend-url.vercel.app
